function foxMsg(ds){
  const st=dayStatus(ds), t=totals(ds), g=S.settings, isToday=ds===todayStr();
  if(st==="none") return {m:"sleep",t:isToday?"עוד לא רשמת כלום היום. מה אכלת? 🍽️":"אין תיעוד ליום הזה."};
  if(st==="cheat") return {m:"party",t:"יום צ'יט! תהנה בשקט, מחר חוזרים למסלול 🍕"};
  if(st==="in") return {m:"star",t:"אתה בול בטווח היעד! ממשיכים ככה 💪"};
  if(st==="over"){ return {m:"worried",t:t.p>=g.protein*0.85?"עברת קצת את הקלוריות, אבל החלבון מעולה. מחר יום חדש!":"עברת את היעד היום — קורה לכולם. מחר מתאפסים 🙂"}; }
  const left=R(g.kcal-t.k);
  return {m:"happy",t:"נשארו לך בערך "+fmt(left)+' קק"ל להיום. יש מקום לעוד חלבון 😉'};
}

