/* ================= ADD SHEET ================= */
let cart=[], sheetOpen=false, searchQ="", saveCombo=false, comboName="";
function openAdd(){ cart=[]; searchQ=""; saveCombo=false; comboName=""; sheetOpen=true; renderSheet(); }
function closeSheet(){ sheetOpen=false; const o=$("#ovl"); if(o) o.remove(); }
function cartRow(it,i){
  return `<div class="cartrow">
    <span class="fe">${it.emoji}</span>
    <div class="fi"><div class="fn">${esc(it.name)}</div>
    <div class="fm num">${esc(it.unit)} · ${fmt(it.per.k*it.qty)} קק"ל · ${fmt(it.per.p*it.qty)} ח'</div></div>
    <div class="stepper">
      <button onclick="cartQty(${i},-1)" aria-label="פחות">−</button>
      <span class="q num">${it.qty}</span>
