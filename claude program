let tab="today", viewDate=todayStr();
function ringColor(st){ return st==="over"?"var(--red)":st==="in"?"var(--green)":st==="cheat"?"var(--purple)":"var(--blue)"; }
function statusChip(st){
  const map={none:["עוד אין נתונים","var(--card2)","var(--ink2)"],under:["מתחת ליעד","var(--blue-soft)","var(--blue-d)"],
