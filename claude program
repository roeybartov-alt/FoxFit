<title>פוקסי · יומן חיטוב</title>
<style>
:root{
  --bg:#F3F7EE; --card:#FFFFFF; --card2:#ECF3E3; --ink:#3C4A33; --ink2:#7E8C71; --line:#DFE8D2;
  --green:#58CC02; --green-d:#46A302; --green-soft:#E3FBCF;
  --blue:#1CB0F6; --blue-d:#1586BC; --blue-soft:#DDF4FE;
  --orange:#FF9600; --orange-d:#C67300; --orange-soft:#FFEFD6;
  --yellow:#FFC800; --yellow-d:#A98200; --yellow-soft:#FFF6D6;
  --red:#FF4B4B; --red-d:#D03333; --red-soft:#FFE3E3;
  --purple:#CE82FF; --purple-d:#A54EDC;
  --ch-bar:#4CA800; --ch-line:#1586BC; --ch-dot:#1CB0F6; --ch-grid:rgba(60,74,51,.12);
  --shadow:0 2px 0 var(--line);
}
@media (prefers-color-scheme: dark){
  :root{
    --bg:#131F24; --card:#202F36; --card2:#18262D; --ink:#EAF3F7; --ink2:#8FA6B0; --line:#33454F;
    --green:#58CC02; --green-d:#3E8F04; --green-soft:#1E3A14;
    --blue:#1CB0F6; --blue-d:#4FC4F8; --blue-soft:#123647;
    --orange:#FF9600; --orange-d:#FFB13D; --orange-soft:#3D2C10;
    --yellow:#FFC800; --yellow-d:#FFD84D; --yellow-soft:#3B3210;
    --red:#FF5B5B; --red-d:#FF8080; --red-soft:#43201F;
    --purple:#CE82FF; --purple-d:#DDA6FF;
    --ch-bar:#63D515; --ch-line:#4FC4F8; --ch-dot:#4FC4F8; --ch-grid:rgba(234,243,247,.14);
    --shadow:0 2px 0 rgba(0,0,0,.35);
  }
}
:root[data-theme="light"]{
  --bg:#F3F7EE; --card:#FFFFFF; --card2:#ECF3E3; --ink:#3C4A33; --ink2:#7E8C71; --line:#DFE8D2;
  --green:#58CC02; --green-d:#46A302; --green-soft:#E3FBCF;
  --blue:#1CB0F6; --blue-d:#1586BC; --blue-soft:#DDF4FE;
  --orange:#FF9600; --orange-d:#C67300; --orange-soft:#FFEFD6;
  --yellow:#FFC800; --yellow-d:#A98200; --yellow-soft:#FFF6D6;
  --red:#FF4B4B; --red-d:#D03333; --red-soft:#FFE3E3;
  --purple:#CE82FF; --purple-d:#A54EDC;
  --ch-bar:#4CA800; --ch-line:#1586BC; --ch-dot:#1CB0F6; --ch-grid:rgba(60,74,51,.12);
  --shadow:0 2px 0 var(--line);
}
:root[data-theme="dark"]{
  --bg:#131F24; --card:#202F36; --card2:#18262D; --ink:#EAF3F7; --ink2:#8FA6B0; --line:#33454F;
  --green:#58CC02; --green-d:#3E8F04; --green-soft:#1E3A14;
  --blue:#1CB0F6; --blue-d:#4FC4F8; --blue-soft:#123647;
  --orange:#FF9600; --orange-d:#FFB13D; --orange-soft:#3D2C10;
  --yellow:#FFC800; --yellow-d:#FFD84D; --yellow-soft:#3B3210;
  --red:#FF5B5B; --red-d:#FF8080; --red-soft:#43201F;
  --purple:#CE82FF; --purple-d:#DDA6FF;
  --ch-bar:#63D515; --ch-line:#4FC4F8; --ch-dot:#4FC4F8; --ch-grid:rgba(234,243,247,.14);
  --shadow:0 2px 0 rgba(0,0,0,.35);
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent}
html,body{margin:0;padding:0}
body{background:var(--bg); color:var(--ink);
  font-family:"Segoe UI","Helvetica Neue",Arial,"Noto Sans Hebrew",sans-serif;
  font-size:16px; line-height:1.45;}
#app{max-width:480px;margin:0 auto;padding:12px 14px 96px;direction:rtl}
button{font-family:inherit;color:inherit;border:none;background:none;cursor:pointer}
input,textarea{font-family:inherit;font-size:16px;color:var(--ink)}
h1,h2,h3{margin:0;text-wrap:balance}
.num{font-variant-numeric:tabular-nums}

/* header */
.hdr{display:flex;align-items:center;justify-content:space-between;padding:6px 2px 12px}
.logo{display:flex;align-items:center;gap:8px;font-weight:900;font-size:22px;letter-spacing:.2px}
.logo .fox-mini{width:34px;height:34px}
.hdr-side{display:flex;align-items:center;gap:8px}
.streak-pill{display:flex;align-items:center;gap:5px;background:var(--orange-soft);color:var(--orange-d);
  font-weight:800;border-radius:999px;padding:5px 12px;font-size:15px}
.gear{font-size:20px;background:var(--card);border:2px solid var(--line);border-radius:12px;padding:6px 9px;box-shadow:var(--shadow)}

/* cards */
.card{background:var(--card);border:2px solid var(--line);border-radius:20px;padding:14px 16px;margin-bottom:12px;box-shadow:var(--shadow)}
.card h2{font-size:13px;font-weight:800;color:var(--ink2);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px}

/* mascot */
.mascot{display:flex;align-items:center;gap:12px}
.mascot svg{width:86px;height:86px;flex:none}
.bubble{position:relative;background:var(--card2);border:2px solid var(--line);border-radius:16px;padding:10px 14px;font-weight:600;font-size:15px}
.bubble::before{content:"";position:absolute;right:-9px;top:34px;border:8px solid transparent;border-left-color:var(--line);transform:scaleX(-1)}

/* date nav */
.datenav{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.datenav .dlabel{font-weight:800;font-size:17px}
.datenav button{font-size:18px;font-weight:900;color:var(--ink2);background:var(--card);border:2px solid var(--line);
  border-radius:12px;padding:4px 12px;box-shadow:var(--shadow)}
.datenav button:disabled{opacity:.3;cursor:default}

/* calorie ring */
.ringwrap{display:flex;align-items:center;gap:16px}
.ring{position:relative;width:150px;height:150px;flex:none}
.ring svg{transform:rotate(-90deg)}
.ring .mid{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
.ring .big{font-size:30px;font-weight:900;line-height:1}
.ring .sub{font-size:12px;font-weight:700;color:var(--ink2);margin-top:4px}
.kstats{flex:1;display:flex;flex-direction:column;gap:6px}
.kstat{display:flex;justify-content:space-between;font-weight:700;font-size:14px}
.kstat b{font-weight:900}
.status-chip{display:inline-block;border-radius:999px;padding:4px 12px;font-weight:800;font-size:13px;margin-top:6px;align-self:flex-start}

/* macro bars */
.macro{margin-bottom:12px}
.macro:last-child{margin-bottom:0}
.macro .mrow{display:flex;justify-content:space-between;font-size:14px;font-weight:800;margin-bottom:5px}
.macro .mrow .goal{color:var(--ink2);font-weight:700}
.mbar{height:14px;border-radius:999px;background:var(--card2);overflow:hidden;border:1px solid var(--line)}
.mbar>div{height:100%;border-radius:999px;transition:width .5s cubic-bezier(.34,1.4,.64,1);min-width:0}

/* buttons */
.btn{display:block;width:100%;text-align:center;font-weight:900;font-size:16px;border-radius:16px;padding:13px;
  color:#fff;background:var(--green);box-shadow:0 4px 0 var(--green-d);transition:transform .06s,box-shadow .06s}
.btn:active{transform:translateY(4px);box-shadow:0 0 0 var(--green-d)}
.btn.orange{background:var(--orange);box-shadow:0 4px 0 #B96D00}
.btn.orange:active{box-shadow:none}
.btn.ghost{background:var(--card);color:var(--ink2);box-shadow:0 4px 0 var(--line);border:2px solid var(--line)}
.btn.ghost:active{box-shadow:none}
.btn.red{background:var(--red);box-shadow:0 4px 0 #A82626}
.btn.red:active{box-shadow:none}
.btn:focus-visible,button:focus-visible{outline:3px solid var(--blue);outline-offset:2px}
.btnrow{display:flex;gap:10px}
.btnrow .btn{flex:1}

/* meals list */
.meal{display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1.5px dashed var(--line)}
.meal:last-child{border-bottom:none}
.meal .fe{font-size:22px;width:30px;text-align:center;flex:none}
.meal .fi{flex:1;min-width:0}
.meal .fn{font-weight:800;font-size:15px}
.meal .fm{font-size:12.5px;color:var(--ink2);font-weight:600}
.meal .fk{font-weight:900;font-size:15px;white-space:nowrap}
.meal .del{color:var(--ink2);font-size:15px;padding:6px;border-radius:8px}
.meal .del:hover{color:var(--red)}
.empty{color:var(--ink2);text-align:center;font-weight:600;padding:14px 0}

/* add sheet */
.overlay{position:fixed;inset:0;background:rgba(19,31,36,.55);z-index:40;display:flex;align-items:flex-end;justify-content:center}
.sheet{background:var(--bg);width:100%;max-width:480px;max-height:88vh;border-radius:24px 24px 0 0;padding:16px 16px 24px;
  overflow-y:auto;direction:rtl;animation:up .22s ease-out}
@keyframes up{from{transform:translateY(40px);opacity:.4}to{transform:none;opacity:1}}
@media (prefers-reduced-motion: reduce){ .sheet{animation:none} .mbar>div{transition:none} .confetti{display:none!important}}
.sheet h3{font-size:18px;font-weight:900;margin-bottom:12px;display:flex;justify-content:space-between;align-items:center}
.sheet .close{font-size:20px;color:var(--ink2);padding:4px 10px}
.freebox{display:flex;gap:8px;margin-bottom:6px}
.freebox input{flex:1;border:2px solid var(--line);border-radius:14px;padding:11px 13px;background:var(--card);font-weight:600}
.freebox button{background:var(--blue);color:#fff;font-weight:900;border-radius:14px;padding:0 18px;box-shadow:0 3px 0 #1180B8}
.hint{font-size:12.5px;color:var(--ink2);font-weight:600;margin:0 2px 12px}
.chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px}
.chip{background:var(--card);border:2px solid var(--line);border-radius:999px;padding:7px 13px;font-weight:800;font-size:13.5px;box-shadow:var(--shadow)}
.chip.combo{background:var(--blue-soft);border-color:var(--blue);color:var(--blue-d)}
.searchbox{width:100%;border:2px solid var(--line);border-radius:14px;padding:11px 13px;background:var(--card);font-weight:600;margin-bottom:8px}
.foodlist{max-height:220px;overflow-y:auto;border:2px solid var(--line);border-radius:14px;background:var(--card);margin-bottom:12px}
.fooditem{display:flex;align-items:center;gap:10px;width:100%;text-align:right;padding:9px 12px;border-bottom:1px solid var(--line);font-size:14.5px}
.fooditem:last-child{border-bottom:none}
.fooditem:hover{background:var(--card2)}
.fooditem .fe{font-size:19px}
.fooditem .fn{font-weight:800;flex:1}
.fooditem .fk{color:var(--ink2);font-weight:700;font-size:12.5px}
.cart{margin-bottom:12px}
.cartrow{display:flex;align-items:center;gap:8px;background:var(--card);border:2px solid var(--line);border-radius:14px;padding:8px 10px;margin-bottom:8px}
.cartrow .fe{font-size:20px}
.cartrow .fi{flex:1;min-width:0}
.cartrow .fn{font-weight:800;font-size:14px}
.cartrow .fm{font-size:12px;color:var(--ink2);font-weight:600}
.stepper{display:flex;align-items:center;gap:2px}
.stepper button{width:30px;height:30px;border-radius:10px;background:var(--card2);border:2px solid var(--line);font-weight:900;font-size:16px;line-height:1}
.stepper .q{min-width:34px;text-align:center;font-weight:900;font-size:15px}
.cartrow .rm{color:var(--ink2);padding:4px 6px}
.savebox{display:flex;align-items:center;gap:8px;margin-bottom:12px;font-weight:700;font-size:14px}
.savebox input[type=checkbox]{width:20px;height:20px;accent-color:var(--green)}
.savebox input[type=text]{flex:1;border:2px solid var(--line);border-radius:10px;padding:7px 10px;background:var(--card)}

/* charts */
.chartwrap{overflow-x:auto}
.chart-tip{position:fixed;z-index:60;background:var(--ink);color:var(--bg);font-weight:800;font-size:13px;
  border-radius:10px;padding:6px 11px;pointer-events:none;transform:translate(-50%,-115%);white-space:nowrap}
.weeknav{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.weeknav button{font-weight:900;color:var(--ink2);background:var(--card2);border-radius:10px;padding:3px 12px;font-size:16px}
.weeknav button:disabled{opacity:.3}
.weeknav .wl{font-weight:800;font-size:14px;color:var(--ink2)}

/* stats */
.statgrid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px}
.stat{background:var(--card);border:2px solid var(--line);border-radius:16px;padding:12px 14px;box-shadow:var(--shadow)}
.stat .v{font-size:24px;font-weight:900;line-height:1.1}
.stat .l{font-size:12px;font-weight:700;color:var(--ink2);margin-top:3px}

/* history list */
.dayrow{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1.5px dashed var(--line)}
.dayrow:last-child{border-bottom:none}
.dayrow .de{font-size:20px;width:28px;text-align:center}
.dayrow .di{flex:1}
.dayrow .dn{font-weight:800;font-size:14.5px}
.dayrow .dm{font-size:12.5px;color:var(--ink2);font-weight:600}
.dayrow .dk{font-weight:900}

/* badges */
.badges{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.badge{background:var(--card);border:2px solid var(--line);border-radius:16px;padding:12px 8px;text-align:center;box-shadow:var(--shadow)}
.badge .be{font-size:30px}
.badge .bn{font-weight:800;font-size:12.5px;margin-top:4px}
.badge .bd{font-size:11px;color:var(--ink2);font-weight:600;margin-top:2px}
.badge.locked{opacity:.45;filter:grayscale(1)}
.badge.locked .be{filter:grayscale(1)}

/* nav */
nav{position:fixed;bottom:0;left:0;right:0;z-index:30;background:var(--card);border-top:2px solid var(--line)}
.navin{max-width:480px;margin:0 auto;display:flex;direction:rtl}
nav button{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;padding:9px 0 10px;font-size:11.5px;font-weight:800;color:var(--ink2)}
nav button .ni{font-size:21px}
nav button.on{color:var(--green-d)}
nav button.on .ni{transform:scale(1.15)}

/* fab */
.fab{position:fixed;bottom:76px;z-index:31;width:60px;height:60px;border-radius:20px;background:var(--green);color:#fff;
  font-size:30px;font-weight:900;box-shadow:0 5px 0 var(--green-d), 0 8px 20px rgba(0,0,0,.18);line-height:1}
.fab:active{transform:translateY(4px);box-shadow:0 1px 0 var(--green-d)}

/* toast + confetti */
.toast{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:70;background:var(--ink);color:var(--bg);
  font-weight:800;border-radius:14px;padding:11px 18px;font-size:14.5px;box-shadow:0 6px 20px rgba(0,0,0,.25);
  display:flex;align-items:center;gap:8px;max-width:90vw;text-align:center}
.confetti{position:fixed;top:-12px;z-index:65;font-size:18px;animation:fall linear forwards;pointer-events:none}
@keyframes fall{to{transform:translateY(105vh) rotate(720deg)}}

/* settings */
.warnbanner{background:var(--red-soft);color:var(--red-d);border:2px solid var(--red);border-radius:14px;padding:10px 14px;font-weight:700;font-size:13.5px;margin-bottom:12px;line-height:1.5}
.setrow{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-bottom:12px;font-weight:800;font-size:14.5px}
.setrow input{width:90px;border:2px solid var(--line);border-radius:10px;padding:8px;background:var(--card);font-weight:800;text-align:center}
.about{font-size:13px;color:var(--ink2);font-weight:600;line-height:1.6}
.io textarea{width:100%;height:70px;border:2px solid var(--line);border-radius:12px;background:var(--card);padding:8px;font-size:12px;direction:ltr}
hr.sep{border:none;border-top:2px dashed var(--line);margin:14px 0}
</style>

<div id="app"></div>
<nav><div class="navin" id="nav"></div></nav>

