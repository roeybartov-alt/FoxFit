/* ================= HEBREW FREE-TEXT PARSER ================= */
const NUMW = {"חצי":0.5,"רבע":0.25,"אחד":1,"אחת":1,"שני":2,"שתי":2,"שניים":2,"שתיים":2,"זוג":2,
"שלוש":3,"שלושה":3,"ארבע":4,"ארבעה":4,"חמש":5,"חמישה":5,"שש":6,"שישה":6,"שבע":7,"שבעה":7,"שמונה":8,"תשע":9,"תשעה":9,"עשר":10,"עשרה":10};
const STOP=new Set(["עם","של","על","עוד","קצת","כף","כפות","כפית","כוס","כוסות","פרוסה","פרוסות","פרוסת","יחידה","יחידות","מנה","מנות","גביע","קערה","צלחת","שקית","בקבוק","פחית","כדור","כדורי","פלח","חופן","קופסה","גרם"]);
const normw = w => w.replace(/[^א-ת0-9a-zA-Z]/g,"");
const stem = w => { let s=w.replace(/^(וה|ה)/,""); if(s.length>3) s=s.replace(/(יות|ים|ות)$/,""); if(s.length>3) s=s.replace(/[הת]$/,""); return s; };
function scoreFood(food, wordsIn){
  const words=wordsIn.map(normw).filter(w=>w.length>1&&!STOP.has(w));
  if(!words.length) return 0;
  const toks=[...food.n.split(/\s+/),...food.syn.flatMap(s=>s.split(/\s+/))]
    .map(normw).filter(t=>t.length>1&&!STOP.has(t));
  let sc=0;
  for(const w of words){
    const sw=stem(w); let best=0;
    for(const t of toks){
      const st_=stem(t);
      if(t===w||st_===sw) best=Math.max(best,3);
      else if(st_.length>2&&sw.length>2&&(st_.startsWith(sw)||sw.startsWith(st_))) best=Math.max(best,2);
      else if(t.length>2&&w.length>2&&(t.includes(w)||w.includes(t))) best=Math.max(best,1);
    }
    sc+=best;
  }
  // phrase bonuses: exact synonym is strongest, then name starting with the query
  const q=words.join(" "), nn=normw(food.n.replace(/\s+/g," "));
  if(food.syn.some(s=>normw(s.replace(/\s+/g," "))===normw(q)||s===q)) sc+=4;
  else if(food.n.startsWith(q)) sc+=3;
  else if(food.n.includes(q)) sc+=1;
  return sc;
}
function matchFood(str){
  const words=str.trim().split(/\s+/).filter(Boolean);
  if(!words.length) return null;
  let best=null,bs=0;
  for(const f of FOODS){
    const s=scoreFood(f,words);
    if(s>bs){bs=s;best=f;}
    else if(s===bs&&best&&s>0){
      const ff=(S.freq[f.n]||0)-(S.freq[best.n]||0);
      if(ff>0||(ff===0&&f.n.length<best.n.length)) best=f;
    }
  }
  return bs>=2?best:null;
}
function parseFree(text){
  const pre=text.replace(/\s+(עם|וגם|ועוד|בתוספת|ליד|ואז)\s+/g,",");
  const parts=pre.split(/,|\+|\n/).flatMap(p=>p.split(/\s+ו(?=[א-ת])/)).map(p=>p.trim()).filter(Boolean);
  const out=[];
  for(const part of parts){
    let qty=1; const toks=[];
    for(const t of part.split(/\s+/)){
      const m=t.replace(",",".").match(/^(\d+(?:\.\d+)?)$/);
      if(m){qty=parseFloat(m[1]);continue;}
      if(NUMW[t]!=null){qty=NUMW[t];continue;}
      toks.push(t);
    }
    const f=matchFood(toks.join(" "));
    out.push({txt:part,qty,food:f});
  }
  return out;
}

