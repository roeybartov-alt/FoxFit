function todayStr(d){ const x=d?new Date(d):new Date(); return x.getFullYear()+"-"+String(x.getMonth()+1).padStart(2,"0")+"-"+String(x.getDate()).padStart(2,"0"); }
function addDays(ds,n){ const d=new Date(ds+"T12:00:00"); d.setDate(d.getDate()+n); return todayStr(d); }
function dayObj(ds){ if(!S.days[ds]) S.days[ds]={entries:[],cheat:false}; return S.days[ds]; }
function totals(ds){ const d=S.days[ds]; const t={k:0,p:0,c:0,f:0};
  if(d) for(const e of d.entries){ t.k+=e.per.k*e.qty; t.p+=e.per.p*e.qty; t.c+=e.per.c*e.qty; t.f+=e.per.f*e.qty; }
  return t; }
const R=n=>Math.round(n);
const fmt=n=>R(n).toLocaleString("he-IL");
const DOW=["א'","ב'","ג'","ד'","ה'","ו'","שבת"];
function heDate(ds){ const d=new Date(ds+"T12:00:00"); return "יום "+DOW[d.getDay()]+" · "+d.getDate()+"."+(d.getMonth()+1); }
function weekStart(ds){ const d=new Date(ds+"T12:00:00"); return addDays(ds,-d.getDay()); }
function isLogged(ds){ const d=S.days[ds]; return !!(d&&(d.entries.length||d.cheat)); }
function dayStatus(ds){ // 'none' | 'cheat' | 'in' | 'under' | 'over'
  const d=S.days[ds]; if(!d||(!d.entries.length&&!d.cheat)) return "none";
  if(d.cheat) return "cheat";
  const t=totals(ds), g=S.settings;
  if(t.k>g.kcal*1.1) return "over";
  if(t.k<g.kcal*0.9) return "under";
  return "in";
}
function isPerfect(ds){ const d=S.days[ds]; if(!d||d.cheat||!d.entries.length) return false;
  const t=totals(ds),g=S.settings; return t.k>=g.kcal*0.9&&t.k<=g.kcal*1.1&&t.p>=g.protein*0.85; }
function streak(){ let n=0, ds=todayStr();
  if(!isLogged(ds)) ds=addDays(ds,-1); // grace: today not yet logged
  while(isLogged(ds)){ n++; ds=addDays(ds,-1); }
  return n; }
function cheatsThisWeek(){ const ws=weekStart(todayStr()); let n=0;
  for(let i=0;i<7;i++){ const d=S.days[addDays(ws,i)]; if(d&&d.cheat) n++; } return n; }

