function nav_day(n){ const nd=addDays(viewDate,n); if(nd>todayStr()) return; viewDate=nd; render(); }
function delEntry(ds,id){ const d=S.days[ds]; if(!d) return; d.entries=d.entries.filter(e=>e.id!==id); save(); render(); }
